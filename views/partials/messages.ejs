<% if(success_msg != ''){ %>
  <div class="alert alert-success">
    <i class="fas fa-check-circle"></i>
    <%= success_msg %>
    <span class="close-btn" onclick="this.parentElement.style.display='none';">&times;</span>
  </div>
<% } %>

<% if(error_msg != ''){ %>
  <div class="alert alert-danger">
    <i class="fas fa-exclamation-circle"></i>
    <%= error_msg %>
    <span class="close-btn" onclick="this.parentElement.style.display='none';">&times;</span>
  </div>
<% } %>

<% if(error != ''){ %>
  <div class="alert alert-danger">
    <i class="fas fa-exclamation-circle"></i>
    <%= error %>
    <span class="close-btn" onclick="this.parentElement.style.display='none';">&times;</span>
  </div>
<% } %>
