<%- include('partials/header') %>

<section class="hero">
    <h1>Discover Amazing Stories</h1>
    <p>Read, share, and inspire with the community.</p>
</section>

<div class="blog-grid">
    <% if (blogs.length > 0) { %>
        <% blogs.forEach(blog => { %>
            <div class="blog-card">
                <div class="blog-image">
                    <img src="<%= blog.image %>" alt="<%= blog.title %>">
                </div>
                <div class="blog-content">
                    <span class="blog-author">By <%= blog.author.username %></span>
                    <h3><%= blog.title %></h3>
                    <p><%= blog.content.substring(0, 100) %>...</p>
                    <a href="/blogs/<%= blog._id %>" class="btn-read">Read More</a>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <p class="no-blogs">No blogs found. Be the first to create one!</p>
    <% } %>
</div>

<%- include('partials/footer') %>
